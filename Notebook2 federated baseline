    "# =============================================================================\n",
    "# PHASE 4: FEDERATED DATA SPLITTING (DIRICHLET)\n",
    "# =============================================================================\n",
    "\n",
    "def dirichlet_split(data, n_clients, alpha, seed=42):\n",
    "    \"\"\"\n",
    "    Split dataset into n_clients non-IID shards using Dirichlet distribution.\n",
    "    Lower alpha = more heterogeneous (each client dominated by 1-2 types).\n",
    "    Higher alpha = more uniform (each client gets balanced types).\n",
    "    \"\"\"\n",
    "    np.random.seed(seed)\n",
    "    \n",
    "    # Group indices by command type\n",
    "    type_indices = {}\n",
    "    for i, sample in enumerate(data):\n",
    "        ct = sample[\"output\"][\"command_type\"]\n",
    "        if ct not in type_indices:\n",
    "            type_indices[ct] = []\n",
    "        type_indices[ct].append(i)\n",
    "    \n",
    "    client_indices = [[] for _ in range(n_clients)]\n",
    "    \n",
    "    for ct, indices in type_indices.items():\n",
    "        np.random.shuffle(indices)\n",
    "        proportions = np.random.dirichlet([alpha] * n_clients)\n",
    "        splits = (proportions * len(indices)).astype(int)\n",
    "        # Fix rounding so total matches\n",
    "        splits[-1] = len(indices) - splits[:-1].sum()\n",
    "        \n",
    "        start = 0\n",
    "        for c, count in enumerate(splits):\n",
    "            client_indices[c].extend(indices[start:start + count])\n",
    "            start += count\n",
    "    \n",
    "    # Shuffle each client's data\n",
    "    client_datasets = []\n",
    "    for indices in client_indices:\n",
    "        np.random.shuffle(indices)\n",
    "        client_data = [data[i] for i in indices]\n",
    "        client_datasets.append(client_data)\n",
    "    \n",
    "    return client_datasets\n",
    "\n",
    "\n",
    "def print_client_distribution(client_datasets, alpha):\n",
    "    \"\"\"Print how data is distributed across clients.\"\"\"\n",
    "    print(f\"\\n  Dirichlet alpha={alpha} | {len(client_datasets)} clients:\")\n",
    "    for c, cdata in enumerate(client_datasets):\n",
    "        types = Counter(s[\"output\"][\"command_type\"] for s in cdata)\n",
    "        dominant = types.most_common(1)[0]\n",
    "        print(f\"    Client {c}: {len(cdata)} samples | \"\n",
    "              f\"Dominant: {dominant[0]} ({dominant[1]}/{len(cdata)} = \"\n",
    "              f\"{dominant[1]/len(cdata)*100:.0f}%)\")\n",
    "\n",
    "\n",
    "# Pre-compute all federated splits\n",
    "print(\"\\nCreating federated data splits...\")\n",
    "all_splits = {}\n",
    "for alpha in ALPHA_VALUES:\n",
    "    client_data = dirichlet_split(train_raw, NUM_CLIENTS, alpha)\n",
    "    all_splits[alpha] = client_data\n",
    "    print_client_distribution(client_data, alpha)\n"
   ]
