    "# =============================================================================\n",
    "# PHASE 8: RUN ALL EXPERIMENTS\n",
    "# =============================================================================\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"RUNNING FEDERATED EXPERIMENTS\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"Start time: {datetime.now().strftime('%H:%M:%S')}\")\n",
    "\n",
    "all_results = {}\n",
    "import gc\n",
    "os.environ[\"TOKENIZERS_PARALLELISM\"] = \"false\"\n",
    "for alpha in ALPHA_VALUES:\n",
    "    \n",
    "    # Get pre-computed client split for this alpha\n",
    "    client_datasets = all_splits[alpha]\n",
    "    \n",
    "    # Reset model to fresh LoRA weights before each experiment\n",
    "    # Re-initialize LoRA from scratch\n",
    "    for name, param in model.named_parameters():\n",
    "        if \"lora_A\" in name:\n",
    "            torch.nn.init.kaiming_uniform_(param, a=np.sqrt(5))\n",
    "        elif \"lora_B\" in name:\n",
    "            torch.nn.init.zeros_(param)\n",
    "    \n",
    "    history = run_federated_experiment(\n",
    "        model=model,\n",
    "        tokenizer=tokenizer,\n",
    "        client_datasets=client_datasets,\n",
    "        val_raw=val_raw,\n",
    "        test_raw=test_raw,\n",
    "        alpha=alpha,\n",
    "        num_rounds=NUM_ROUNDS,\n",
    "        local_epochs=LOCAL_EPOCHS,\n",
    "    )\n",
    "    \n",
    "    all_results[str(alpha)] = history\n",
    "    \n",
    "    # Save intermediate results after each alpha experiment\n",
    "    results_path = os.path.join(OUTPUT_DIR, \"fedavg_results.json\")\n",
    "    with open(results_path, 'w') as f:\n",
    "        json.dump(all_results, f, indent=2)\n",
    "    print(f\"\\n  Results saved to {results_path}\")\n",
    "\n",
    "print(f\"\\nAll experiments completed at {datetime.now().strftime('%H:%M:%S')}\")\n"
   ]
